# Railway-first starter defaults
ENVIRONMENT=local
PROJECT_NAME="Railway FastAPI React Template"

# Frontend URL used in emails and password reset links
FRONTEND_HOST=http://localhost:5173

# CORS origins for local dev; in Railway set this to your deployed frontend URL
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"

# Security
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Database
# Railway production: prefer DATABASE_URL from Railway Postgres
DATABASE_URL=
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

SENTRY_DSN=
