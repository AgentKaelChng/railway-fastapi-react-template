# Copy values from here into Railway backend/frontend service variables for production.
# Replace placeholders before deploying.

# Backend service
ENVIRONMENT=production
PROJECT_NAME=Your App Name
SECRET_KEY=replace-with-a-long-random-secret
FIRST_SUPERUSER=you@example.com
FIRST_SUPERUSER_PASSWORD=replace-with-a-strong-password
DATABASE_URL=${{Postgres.DATABASE_URL}}
FRONTEND_HOST=https://app.example.com
BACKEND_CORS_ORIGINS=["https://app.example.com"]
WEB_CONCURRENCY=2

# Optional backend variables
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAILS_FROM_EMAIL=
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_SSL=false
# SENTRY_DSN=

# Frontend service
VITE_API_URL=https://api.example.com
